[
  {{- range $index, $page := .Site.RegularPages -}}
    {{- if $index -}},{{- end -}}
    {{- $coverUrl := "" -}}
    {{- $baseName := $page.File.BaseFileName -}}
    {{- $strippedName := replaceRE `^\d{4}-\d{2}-\d{2}-` "" $baseName -}}
    {{- range (slice "png" "jpg" "jpeg" "webp" "gif") -}}
      {{- if not $coverUrl -}}
        {{- /* 1. Try to find in assets/images/covers/ */ -}}
        {{- $resPath1 := printf "images/covers/%s.%s" $strippedName . -}}
        {{- $res1 := resources.Get $resPath1 -}}
        {{- if $res1 -}}
          {{- $coverUrl = $res1.RelPermalink -}}
        {{- else -}}
          {{- $resPath2 := printf "images/covers/%s.%s" $baseName . -}}
          {{- $res2 := resources.Get $resPath2 -}}
          {{- if $res2 -}}
            {{- $coverUrl = $res2.RelPermalink -}}
          {{- else -}}
            {{- /* 2. Fall back to static/images/covers/ */ -}}
            {{- $statPath1 := printf "static/images/covers/%s.%s" $strippedName . -}}
            {{- if fileExists $statPath1 -}}
              {{- $coverUrl = printf "/images/covers/%s.%s" $strippedName . | relURL -}}
            {{- else -}}
              {{- $statPath2 := printf "static/images/covers/%s.%s" $baseName . -}}
              {{- if fileExists $statPath2 -}}
                {{- $coverUrl = printf "/images/covers/%s.%s" $baseName . | relURL -}}
              {{- end -}}
            {{- end -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {
      "title": {{ $page.Title | jsonify }},
      "permalink": {{ $page.Permalink | jsonify }},
      "summary": {{ $page.Summary | plainify | jsonify }},
      "content": {{ $page.Content | plainify | jsonify }},
      "date": {{ $page.Date.Format "January 2, 2006" | jsonify }},
      "tags": {{ $page.Params.tags | default (slice) | jsonify }},
      "cover": {{ $coverUrl | jsonify }}
    }
  {{- end -}}
]
