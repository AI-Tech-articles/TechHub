[
  {{- range $index, $page := ((where .Site.RegularPages "Section" "posts").ByDate.Reverse) -}}
    {{- if $index -}},{{- end -}}
    {{- $coverUrl := "" -}}
    {{- $baseName := $page.File.BaseFileName -}}
    {{- $strippedName := replaceRE `^\d{4}-\d{2}-\d{2}-` "" $baseName -}}
    {{- range (slice "png" "jpg" "jpeg" "webp" "gif") -}}
      {{- $ext := . -}}
      {{- if not $coverUrl -}}
        {{- range (slice (printf "%s-cover" $strippedName) (printf "%s-cover" $baseName) $strippedName $baseName) -}}
          {{- $namePattern := . -}}
          {{- if not $coverUrl -}}
            {{- /* 1. Try to find in assets/images/covers/ */ -}}
            {{- $resPath := printf "images/covers/%s.%s" $namePattern $ext -}}
            {{- $res := resources.Get $resPath -}}
            {{- if $res -}}
              {{- $coverUrl = $res.RelPermalink -}}
            {{- else -}}
              {{- /* 2. Fall back to static/images/covers/ */ -}}
              {{- $statPath := printf "static/images/covers/%s.%s" $namePattern $ext -}}
              {{- if fileExists $statPath -}}
                {{- $coverUrl = printf "/images/covers/%s.%s" $namePattern $ext | relURL -}}
              {{- end -}}
            {{- end -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {{- $postTopics := slice -}}
    {{- $raw := $page.RawContent -}}
    {{- $topicsMatch := findRE `(?s)(?:##|###) Topics\s*[\r\n]+[\s\r\n]*([^\r\n]+)` $raw 1 -}}
    {{- if $topicsMatch -}}
      {{- $match := index $topicsMatch 0 -}}
      {{- $topicsLine := replaceRE `(?s)^.*?(?:##|###) Topics\s*` "" $match -}}
      {{- $topicsLine = trim $topicsLine " \n\r" -}}
      {{- $rawTopics := split $topicsLine "·" -}}
      {{- range $rawTopics -}}
        {{- $t := trim . " \n\r" -}}
        {{- if $t -}}
          {{- $postTopics = $postTopics | append $t -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {
      "title": {{ $page.Title | jsonify }},
      "permalink": {{ $page.Permalink | jsonify }},
      "summary": {{ $page.Summary | plainify | jsonify }},
      "content": {{ $page.Content | plainify | jsonify }},
      "date": {{ $page.Date.Format "January 2, 2006" | jsonify }},
      "tags": {{ $postTopics | jsonify }},
      "cover": {{ $coverUrl | jsonify }},
      "reading_time": {{ $page.Params.reading_time | default 0 | jsonify }}
    }
  {{- end -}}
]
